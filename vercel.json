{
  "buildCommand": "node scripts/build-all.mjs",
  "outputDirectory": "dist",
  "installCommand": "true",
  "rewrites": [
    { "source": "/ru", "destination": "/ru/" },
    { "source": "/et", "destination": "/et/" },
    { "source": "/en", "destination": "/en/" },
    { "source": "/gcal-test", "destination": "/gcal-test/index.html" },
    { "source": "/gcal-test/(.*)", "destination": "/gcal-test/index.html" }
  ]
}
